# ── SignalSense environment variables ──────────────────────────────────────────

# Login credentials
# Option A — plaintext (fine for local dev)
SS_USERNAME=admin
SS_PASSWORD=changeme

# Option B — hashed password (recommended for shared/deployed use)
# Generate with: python -c "import hashlib; print(hashlib.sha256('yourpass'.encode()).hexdigest())"
# SS_USERNAME=admin
# SS_PASSWORD_HASH=<sha256 hex digest>

# AI analysis
ANTHROPIC_API_KEY=sk-ant-your-key-here
